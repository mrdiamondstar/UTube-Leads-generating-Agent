# ---- Backend ----
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
SECRET_KEY=change-me-in-production

# Postgres
POSTGRES_USER=cip
POSTGRES_PASSWORD=cip
POSTGRES_DB=cip
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async URL used by the app (asyncpg). Compose overrides host to the service name.
DATABASE_URL=postgresql+asyncpg://cip:cip@postgres:5432/cip

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# YouTube provider. Default is the REAL YouTube Data API v3.
# "mock" is a test double only (offline dev / tests).
YOUTUBE_PROVIDER=api
# Read from env; NEVER hardcode. Get one from Google Cloud Console (YouTube Data API v3).
YOUTUBE_API_KEY=your-youtube-data-api-v3-key-here

# YouTube API operational controls
YOUTUBE_DAILY_QUOTA=10000
YOUTUBE_QUOTA_SAFETY_MARGIN=100
YOUTUBE_CACHE_TTL_SECONDS=3600
YOUTUBE_MIN_REQUEST_INTERVAL_MS=50
YOUTUBE_MAX_CONCURRENCY=5
YOUTUBE_MAX_RETRIES=4
YOUTUBE_RECENT_VIDEOS=10
YOUTUBE_PAGE_SIZE=50

# Razorpay (payments). Leave blank for demo mode; fill in to enable live checkout.
# Get keys from Razorpay Dashboard → Settings → API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# Business rules
EXCLUDED_COUNTRIES=IN
# Underperformance: a channel is a lead when actual views are below this
# fraction of expected views for its subscriber count.
UNDERPERFORMANCE_RATIO=0.5
# Audience floor: only consider creators with at least this many subscribers.
# Smaller channels are dropped at discovery. Set 0 to disable.
MIN_SUBSCRIBERS=10000
# Activity: a creator must have uploaded within this many days (~6 months) to
# qualify as a lead. Stale channels are disqualified. Set 0 to disable.
ACTIVE_WITHIN_DAYS=180
# Discovery reuse: if the same niche was discovered within this many hours,
# reuse those results instead of spending YouTube quota again (unless the user
# clicks "Run fresh anyway"). Set 0 to disable and always re-run.
DISCOVERY_REUSE_HOURS=24
# YouTube API Terms compliance: purge channel/video data not refreshed within
# this many days (required <= 30). The /maintenance/cleanup endpoint enforces it.
DATA_RETENTION_DAYS=30
# Shared secret to protect the maintenance endpoint (so a public cron can call
# it). Set a long random string in production; blank leaves the endpoint open.
MAINTENANCE_TOKEN=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
