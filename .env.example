# ---- Backend ----
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
SECRET_KEY=change-me-in-production

# Postgres
POSTGRES_USER=cip
POSTGRES_PASSWORD=cip
POSTGRES_DB=cip
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async URL used by the app (asyncpg). Compose overrides host to the service name.
DATABASE_URL=postgresql+asyncpg://cip:cip@postgres:5432/cip

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# YouTube provider. Default is the REAL YouTube Data API v3.
# "mock" is a test double only (offline dev / tests).
YOUTUBE_PROVIDER=api
# Read from env; NEVER hardcode. Get one from Google Cloud Console (YouTube Data API v3).
YOUTUBE_API_KEY=your-youtube-data-api-v3-key-here

# YouTube API operational controls
YOUTUBE_DAILY_QUOTA=10000
YOUTUBE_QUOTA_SAFETY_MARGIN=100
YOUTUBE_CACHE_TTL_SECONDS=3600
YOUTUBE_MIN_REQUEST_INTERVAL_MS=50
YOUTUBE_MAX_CONCURRENCY=5
YOUTUBE_MAX_RETRIES=4
YOUTUBE_RECENT_VIDEOS=10
YOUTUBE_PAGE_SIZE=50

# Razorpay (payments). Leave blank for demo mode; fill in to enable live checkout.
# Get keys from Razorpay Dashboard → Settings → API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# Business rules
EXCLUDED_COUNTRIES=IN
# Underperformance: a channel is a lead when actual views are below this
# fraction of expected views for its subscriber count.
UNDERPERFORMANCE_RATIO=0.5

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
